# =============================================================================
# Skipperbot Platform — .env.example
# =============================================================================
#
# Copy this file to .env and fill in the REQUIRED values below.
# Everything in the OPTIONAL section is off by default and only needed
# to enable specific capabilities.
#
# Just TWO required values for the Docker path:
#   1. OPENAI_API_KEY        — your key, from https://platform.openai.com/api-keys
#   2. POSTGRES_PASSWORD     — pick any strong password
# The agent builds its database connection from POSTGRES_PASSWORD automatically;
# there is no separate DSN to keep in sync. Native/external DB users can set the
# advanced SKIPPERBOT_DB_DSN override instead (see the DB section below).
#
# See docs/01-base-platform-setup.md for the full setup walkthrough.
# See docs/03-extended-functionality.md for optional-integration setup.

# =============================================================================
# REQUIRED — fill these in before first boot
# =============================================================================

# ----- OpenAI API key -----
# Get one at https://platform.openai.com/api-keys (paid account).
OPENAI_API_KEY=

# ----- Postgres password (Docker path: the ONLY DB value you set) -----
# The Docker `db` container is created with this password on first boot, and
# the agent builds its connection string from it automatically. You do NOT
# also write a DSN — that duplication is gone.
POSTGRES_PASSWORD=CHANGE_ME

# ----- Secret-encryption key -----
# Encrypts secret settings (API keys, tokens) that you save through the
# Settings UI, so they're stored as ciphertext in the database (a leaked DB
# backup yields nothing usable). The platform boots fine without it, but you
# can't save/read encrypted secrets until it's set.
# Generate one with:  python -m app_platform.secrets
# Keep it safe and stable — changing it makes previously-saved secrets
# unreadable (you'd re-enter them).
SKIPPERBOT_SECRET_KEY=

# ----- Optional DB overrides -----
# Defaults (used when not set) match the `db` container: user skipperbot_user,
# database skipperbot, host db, port 5432. Override only if you need to.
#POSTGRES_USER=skipperbot_user
#POSTGRES_DB=skipperbot
# Host port the db container is published on (for external tools like DBeaver,
# reachable at <host>:<port>, e.g. skipper-pi.local:5432). Change only if 5432
# is already in use on the host. The agent always uses db:5432 in-network.
#POSTGRES_PORT=5432

# ----- Full connection string (ADVANCED — usually leave unset) -----
# Set this ONLY for a native install (your own Postgres) or an external/SSL
# database. If set, it takes precedence over the POSTGRES_* vars above.
#   Native (Postgres on the same host as the agent):
#SKIPPERBOT_DB_DSN=dbname=skipperbot user=skipperbot_user password=CHANGE_ME host=localhost port=5432
#   External / URI form with options:
#SKIPPERBOT_DB_DSN=postgresql://user:pass@db.example.com:5432/skipperbot?sslmode=require

# =============================================================================
# CONFIGURED IN THE SETTINGS UI (not here)
# =============================================================================
# These integrations + platform settings now live in the Settings app and are
# stored in the database (secrets encrypted at rest via SKIPPERBOT_SECRET_KEY).
# Do NOT set them in .env — configure them in the running app:
#
#   Settings → Integrations : Discord token, Brave Search key,
#                             OpenAI admin key, Weather key
#   Settings → System       : AI model names, LAN/Public URLs, max session
#                             turns, show-entity-ids, debug-tokens, timezone
#   Settings → Automation    : Home Assistant URL + long-lived token
#   Settings → Notifications : Pushover app token (admin); each person then
#                             opts into Pushover from the Notifications app
#   Settings → Notifications : FCM service-account JSON (mobile push)
#   Settings → Email         : Gmail OAuth client id/secret/redirect
#   Settings → Backups       : Google Drive service-account JSON + impersonate email
#
# (Generate SKIPPERBOT_SECRET_KEY above first, or let the agent auto-create it
#  on first boot, so secret values can be saved.)

# =============================================================================
# OPTIONAL — still set via .env (settings-UI migration in progress).
# Skipperbot runs fine without any of these.
# See docs/03-extended-functionality.md for setup of each.
# =============================================================================

# ----- Wake-word voice ("Hey Skipper") for skipperbot-voice -----
# PICOVOICE_API_KEY=

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Bypass /api/* auth for requests originating from 127.0.0.1 / ::1. Off by default.
# DEV_ALLOW_UNAUTH_LOCALHOST=false
