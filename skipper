#!/usr/bin/env bash
# =============================================================================
# skipper — thin shim that forwards to skipper.sh (the real launcher).
# =============================================================================
# This file exists only so `./skipper` (no extension, like `claude`)
# keeps working. ALL logic lives in skipper.sh — edit that, never this — so the
# two can never drift. On Windows use skipper.bat / skipper.ps1 instead.
# =============================================================================
# Invoke via `bash` (not a direct exec) so this works even if skipper.sh's
# executable bit didn't survive the checkout (e.g. cloned on Windows).
_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
exec bash "$_dir/skipper.sh" "$@"
